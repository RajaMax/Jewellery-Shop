# Copy this file to ".env" and adjust the values.

# Port the API listens on
PORT=5000

# MongoDB connection string.
# Local install (default):
MONGODB_URI=mongodb://127.0.0.1:27017/jewellery
# MongoDB Atlas example:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/jewellery

# Secret used to sign admin login tokens. Change this to any long random string.
JWT_SECRET=change-this-to-a-long-random-secret

# The single master password for the admin panel.
ADMIN_PASSWORD=admin123

# Where the storefront/admin frontend runs (used for CORS).
CLIENT_URL=http://localhost:5173

# Where uploaded product images are stored.
# Leave blank to use backend/uploads. To keep images safe across re-deploys,
# set an ABSOLUTE path OUTSIDE the project folder, e.g.:
#   Windows: UPLOAD_DIR=C:/jewellery-data/uploads
#   Linux:   UPLOAD_DIR=/var/data/jewellery/uploads
# NOTE: this only survives re-deploys on a host with a PERSISTENT disk
# (a VPS, or a paid disk). On ephemeral free hosts like Render's free tier
# the whole filesystem resets, so use Cloudinary instead.
UPLOAD_DIR=
